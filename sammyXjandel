-- ========== AIMBOT CORE (NO WALLCHECK) ==========
local function getClosestTargetAimbot()
    local closestTarget = nil
    local closestDistance = math.huge
    local mousePos = userInputService:GetMouseLocation()
    local fov = settings.aimbot.fovRadius
    
    for _, plr in ipairs(players:GetPlayers()) do
        if plr ~= player then
            local targetTeamSetting = settings.aimbot.targetTeam
            local isEnemy = plr.Team ~= player.Team
            
            if targetTeamSetting == "Enemy" and not isEnemy then goto continue end
            if targetTeamSetting == "Team" and isEnemy then goto continue end
            
            local char = plr.Character
            if char and char:FindFirstChild(settings.aimbot.targetPart) then
                local targetPart = char[settings.aimbot.targetPart]
                local screenPos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                
                if onScreen then
                    local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if distance < closestDistance and distance < fov then
                        closestTarget = targetPart
                        closestDistance = distance
                    end
                end
            end
        end
        ::continue::
    end
    return closestTarget
end

-- ========== TRIGGERBOT CORE (WITH WALLCHECK) ==========
local function getPlayerAtCrosshair()
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    local ray = camera:ScreenPointToRay(screenCenter.X, screenCenter.Y)
    local ignoreList = {player.Character}
    
    local hit = workspace:FindPartOnRayWithIgnoreList(Ray.new(ray.Origin, ray.Direction * 1000), ignoreList)
    
    if hit and hit.Parent then
        local hitCharacter = hit:FindFirstAncestorWhichIsA("Model")
        if hitCharacter and hitCharacter:FindFirstChild("Humanoid") then
            local targetPlayer = players:GetPlayerFromCharacter(hitCharacter)
            if targetPlayer and targetPlayer ~= player then
                local targetTeamSetting = settings.triggerbot.targetTeam
                local isEnemy = targetPlayer.Team ~= player.Team
                
                if targetTeamSetting == "Enemy" and not isEnemy then return nil end
                if targetTeamSetting == "Team" and isEnemy then return nil end
                return targetPlayer
            end
        end
    end
    return nil
end

-- ========== MOUSE INPUT SIMULATION ==========
local function simulateMouseButton(state)
    if state then
        virtualInput:SendMouseButtonEvent(0, 0, 0, true, Enum.UserInputType.MouseButton1, false)
        holdingM1 = true
    else
        virtualInput:SendMouseButtonEvent(0, 0, 0, false, Enum.UserInputType.MouseButton1, false)
        holdingM1 = false
    end
end

-- ========== AIMBOT MOVEMENT ==========
local function moveMouseToTarget(targetPart)
    if not targetPart then return end
    local screenPos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
    if not onScreen then return end
    
    local mousePos = userInputService:GetMouseLocation()
    local moveX = (screenPos.X - mousePos.X) * (settings.aimbot.sensitivity / 100)
    local moveY = (screenPos.Y - mousePos.Y) * (settings.aimbot.sensitivity / 100)
    
    if typeof(mousemoverel) == "function" then
        mousemoverel(moveX, moveY)
    end
end

-- ========== INPUT HANDLING ==========
userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        rightMouseDown = true
    end
end)

userInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        rightMouseDown = false
        if holdingM1 then
            simulateMouseButton(false)
        end
    end
end)

-- ========== MAIN LOOP ==========
runService.RenderStepped:Connect(function()
    if not settings.masterEnabled then return end
    
    -- Aimbot (NO WALLCHECK) - activates when holding RMB and aimbot enabled
    if rightMouseDown and settings.aimbot.enabled then
        local target = getClosestTargetAimbot()
        if target then
            moveMouseToTarget(target)
        end
    end
    
    -- Triggerbot (WITH WALLCHECK) - activates when holding RMB and triggerbot enabled
    if rightMouseDown and settings.triggerbot.enabled then
        local target = getPlayerAtCrosshair()
        if target then
            local currentTime = tick() * 1000
            if currentTime - lastShotTime >= settings.triggerbot.delay then
                lastShotTime = currentTime
                if not holdingM1 then
                    simulateMouseButton(true)
                end
            end
        else
            if holdingM1 then
                simulateMouseButton(false)
            end
        end
    end
end)

-- ========== ESP ==========
local espObjects = {}

local function updateESP()
    for _, obj in pairs(espObjects) do
        pcall(function() obj:Destroy() end)
    end
    espObjects = {}
    
    if not settings.visuals.enabled or not settings.masterEnabled then return end
    
    for _, plr in ipairs(players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local isEnemy = plr.Team ~= player.Team
            local showBox = (isEnemy and settings.visuals.enemyBoxes) or (not isEnemy and settings.visuals.teamBoxes)
            
            if showBox then
                local rootPart = plr.Character.HumanoidRootPart
                local screenPos, onScreen = camera:WorldToScreenPoint(rootPart.Position)
                if onScreen then
                    local box = Instance.new("Frame")
                    box.Size = UDim2.new(0, 55, 0, 110)
                    box.Position = UDim2.new(0, screenPos.X - 27, 0, screenPos.Y - 55)
                    box.BackgroundTransparency = 0.75
                    box.BackgroundColor3 = isEnemy and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(50, 255, 50)
                    box.BorderSizePixel = 1
                    box.BorderColor3 = Color3.fromRGB(255, 255, 255)
                    local boxCorner = Instance.new("UICorner")
                    boxCorner.CornerRadius = UDim.new(0, 6)
                    boxCorner.Parent = box
                    box.Parent = player.PlayerGui
                    table.insert(espObjects, box)
                    
                    if settings.visuals.showNames then
                        local nameLabel = Instance.new("TextLabel")
                        nameLabel.Size = UDim2.new(1, 0, 0, 18)
                        nameLabel.Position = UDim2.new(0, 0, 1, 2)
                        nameLabel.BackgroundTransparency = 1
                        nameLabel.Text = plr.Name
                        nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                        nameLabel.TextSize = 10
                        nameLabel.Font = Enum.Font.GothamBold
                        nameLabel.TextStrokeTransparency = 0.5
                        nameLabel.Parent = box
                        table.insert(espObjects, nameLabel)
                    end
                end
            end
        end
    end
end

runService.RenderStepped:Connect(function()
    updateESP()
end)
