-- ========== TRIGGERBOT CORE LOGIC ==========
-- Function to get player at crosshair with ACCURATE wallcheck (won't shoot through walls)

local function getPlayerAtCrosshair()
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    local ray = camera:ScreenPointToRay(screenCenter.X, screenCenter.Y)
    
    local ignoreList = {player.Character}
    local hit, hitPosition, hitNormal, hitMaterial = workspace:FindPartOnRayWithIgnoreList(Ray.new(ray.Origin, ray.Direction * 1000), ignoreList)
    
    if hit and hit.Parent then
        -- Check if we hit a player directly
        local hitCharacter = hit:FindFirstAncestorWhichIsA("Model")
        if hitCharacter and hitCharacter:FindFirstChild("Humanoid") then
            local targetPlayer = players:GetPlayerFromCharacter(hitCharacter)
            if targetPlayer and targetPlayer ~= player then
                -- Check target team setting
                local targetTeamSetting = settings.ambot.targetTeam
                local isEnemy = targetPlayer.Team ~= player.Team
                
                if targetTeamSetting == "Enemy" and not isEnemy then
                    return nil
                end
                if targetTeamSetting == "Team" and isEnemy then
                    return nil
                end
                return targetPlayer
            end
        end
    end
    
    -- If visibility check is enabled and we didn't hit a player directly, check if there's a player behind obstacles
    if settings.ambot.visibilityCheck then
        local closestPlayer = nil
        local closestDistance = math.huge
        
        for _, plr in ipairs(players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local targetHitbox = plr.Character:FindFirstChild(settings.ambot.hitbox) or plr.Character:FindFirstChild("HumanoidRootPart")
                if targetHitbox then
                    local targetPos = targetHitbox.Position
                    local direction = (targetPos - camera.CFrame.Position).Unit
                    local distanceToTarget = (targetPos - camera.CFrame.Position).Magnitude
                    
                    -- Cast ray from camera to player's hitbox
                    local rayToPlayer = Ray.new(camera.CFrame.Position, direction * distanceToTarget)
                    local hitObstacle, hitPos = workspace:FindPartOnRayWithIgnoreList(rayToPlayer, ignoreList)
                    
                    -- Check if the ray hit the player directly
                    local hitCharacter = hitObstacle and hitObstacle:FindFirstAncestorWhichIsA("Model")
                    if hitCharacter == plr.Character then
                        -- Check if crosshair is on this player
                        local screenPos, onScreen = camera:WorldToScreenPoint(targetPos)
                        if onScreen then
                            local distToCenter = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                            if distToCenter < 50 and distToCenter < closestDistance then
                                -- Check target team setting
                                local targetTeamSetting = settings.ambot.targetTeam
                                local isEnemy = plr.Team ~= player.Team
                                
                                if targetTeamSetting == "Enemy" and isEnemy then
                                    closestPlayer = plr
                                    closestDistance = distToCenter
                                elseif targetTeamSetting == "Team" and not isEnemy then
                                    closestPlayer = plr
                                    closestDistance = distToCenter
                                elseif targetTeamSetting == "All" then
                                    closestPlayer = plr
                                    closestDistance = distToCenter
                                end
                            end
                        end
                    end
                end
            end
        end
        
        return closestPlayer
    end
    
    return nil
end

-- Mouse input handling
local virtualInput = game:GetService("VirtualInputManager")

local function simulateMouseButton(button, state)
    if button == Enum.UserInputType.MouseButton1 then
        if state then
            virtualInput:SendMouseButtonEvent(0, 0, 0, true, Enum.UserInputType.MouseButton1, false)
            holdingM1 = true
        else
            virtualInput:SendMouseButtonEvent(0, 0, 0, false, Enum.UserInputType.MouseButton1, false)
            holdingM1 = false
        end
    end
end

-- Triggerbot logic
local function onTrigger()
    if not settings.masterEnabled then return end
    if not settings.ambot.triggerbot.enabled then return end
    if not rightMouseDown then return end
    
    local target = getPlayerAtCrosshair()
    if target then
        local currentTime = tick() * 1000
        if currentTime - lastShotTime >= settings.ambot.triggerbot.delay then
            lastShotTime = currentTime
            
            if not holdingM1 then
                simulateMouseButton(Enum.UserInputType.MouseButton1, true)
            end
        end
    else
        if holdingM1 then
            simulateMouseButton(Enum.UserInputType.MouseButton1, false)
        end
    end
end

-- Input handling for right mouse button
