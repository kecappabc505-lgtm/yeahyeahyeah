-- Helper function to create slider
local function createSlider(parent, labelText, minVal, maxVal, bindVar, order)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 40)
    frame.BackgroundTransparency = 1
    frame.LayoutOrder = order
    frame.Parent = parent
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 18)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.Parent = frame
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0.3, 0, 0, 18)
    valueLabel.Position = UDim2.new(0.7, 0, 0, 0)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = tostring(bindVar)
    valueLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
    valueLabel.TextSize = 12
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Font = Enum.Font.Gotham
    valueLabel.Parent = frame
    
    local slider = Instance.new("Frame")
    slider.Size = UDim2.new(1, 0, 0, 4)
    slider.Position = UDim2.new(0, 0, 0, 26)
    slider.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
    slider.Parent = frame
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((bindVar - minVal) / (maxVal - minVal), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
    fill.BorderSizePixel = 0
    fill.Parent = slider
    
    local function updateSlider(value)
        local newVal = math.clamp(value, minVal, maxVal)
        bindVar = newVal
        valueLabel.Text = tostring(newVal)
        fill.Size = UDim2.new((newVal - minVal) / (maxVal - minVal), 0, 1, 0)
    end
    
    slider.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            while userInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
                local x = (input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X
                local val = minVal + (maxVal - minVal) * math.clamp(x, 0, 1)
                updateSlider(val)
                runService.RenderStepped:Wait()
            end
        end
    end)
    
    return frame
end

