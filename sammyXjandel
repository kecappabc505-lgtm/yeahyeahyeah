-- Simple ESP implementation
local espObjects = {}

local function updateESP()
    if not settings.visuals.enabled then
        for _, obj in pairs(espObjects) do
            pcall(function() obj:Destroy() end)
        end
        espObjects = {}
        return
    end
    
    for _, obj in pairs(espObjects) do
        pcall(function() obj:Destroy() end)
    end
    espObjects = {}
    
    for _, plr in ipairs(players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local isEnemy = plr.Team ~= player.Team
            local showBoxes = (isEnemy and settings.visuals.enemy.boxes) or (not isEnemy and settings.visuals.team.boxes)
            
            if showBoxes then
                local rootPart = plr.Character.HumanoidRootPart
                local screenPos, onScreen = camera:WorldToScreenPoint(rootPart.Position)
                if onScreen then
                    local box = Instance.new("Frame")
                    box.Size = UDim2.new(0, 50, 0, 100)
                    box.Position = UDim2.new(0, screenPos.X - 25, 0, screenPos.Y - 50)
                    box.BackgroundTransparency = 0.7
                    box.BackgroundColor3 = isEnemy and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 0)
                    box.BorderSizePixel = 1
                    box.BorderColor3 = Color3.fromRGB(255, 255, 255)
                    box.Parent = screenGui
                    table.insert(espObjects, box)
                    
                    local nameLabel = Instance.new("TextLabel")
                    nameLabel.Size = UDim2.new(1, 0, 0, 16)
                    nameLabel.Position = UDim2.new(0, 0, 1, 0)
                    nameLabel.BackgroundTransparency = 1
                    nameLabel.Text = plr.Name
                    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                    nameLabel.TextSize = 10
                    nameLabel.Font = Enum.Font.Gotham
                    nameLabel.Parent = box
                    table.insert(espObjects, nameLabel)
                end
            end
        end
    end
end

runService.RenderStepped:Connect(function()
    updateESP()
end)

